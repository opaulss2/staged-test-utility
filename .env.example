# TPMS stage3 SSH restart settings
TPMS_SSH_TIMEOUT_SECONDS=15

# First hop: SGA
TPMS_SGA_HOST=169.254.4.10
TPMS_SGA_USER=swupdate
TPMS_SGA_PASSWORD=swupdate

# Second hop: VCU via SGA
TPMS_VCU_HOST=198.19.0.1
TPMS_VCU_USER=root
TPMS_VCU_PASSWORD=root

# Restart command executed on VCU
TPMS_TAWM_RESTART_COMMAND=/opt/csp/bin/em_control --restart tyre_and_wheel_monitor

# Existing SWUT setting (kept here for convenience)
SWUT_HPA_PIN=FFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF
